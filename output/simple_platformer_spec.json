{
  "name": "Simple Platformer",
  "description": "A basic platformer game with simple controls",
  "extensions": [],
  "stage": {
    "variables": {},
    "broadcasts": {},
    "backdrops": [
      {
        "name": "Backdrop1",
        "costume": "backdrop1"
      }
    ]
  },
  "sprites": [
    {
      "name": "Player",
      "costume": "cat",
      "x": -100,
      "y": 0,
      "blocks": {
        "onStart": [
          {
            "opcode": "event_whenflagclicked",
            "next": "foreverLoop"
          }
        ],
        "foreverLoop": {
          "opcode": "control_forever",
          "inputs": {
            "SUBSTACK": [
              2,
              "checkKeys"
            ]
          }
        },
        "checkKeys": {
          "opcode": "control_if",
          "inputs": {
            "CONDITION": [
              2,
              "keyRightArrow"
            ],
            "SUBSTACK": [
              2,
              "moveRight"
            ]
          },
          "next": "checkLeft"
        },
        "checkLeft": {
          "opcode": "control_if",
          "inputs": {
            "CONDITION": [
              2,
              "keyLeftArrow"
            ],
            "SUBSTACK": [
              2,
              "moveLeft"
            ]
          },
          "next": "checkJump"
        },
        "checkJump": {
          "opcode": "control_if",
          "inputs": {
            "CONDITION": [
              2,
              "keySpace"
            ],
            "SUBSTACK": [
              2,
              "jump"
            ]
          }
        },
        "keyRightArrow": {
          "opcode": "sensing_keypressed",
          "inputs": {
            "KEY_OPTION": [
              "right arrow",
              null
            ]
          }
        },
        "keyLeftArrow": {
          "opcode": "sensing_keypressed",
          "inputs": {
            "KEY_OPTION": [
              "left arrow",
              null
            ]
          }
        },
        "keySpace": {
          "opcode": "sensing_keypressed",
          "inputs": {
            "KEY_OPTION": [
              "space",
              null
            ]
          }
        },
        "moveRight": {
          "opcode": "motion_changexby",
          "inputs": {
            "DX": [
              1,
              [
                4,
                "10"
              ]
            ]
          }
        },
        "moveLeft": {
          "opcode": "motion_changexby",
          "inputs": {
            "DX": [
              1,
              [
                4,
                "-10"
              ]
            ]
          }
        },
        "jump": {
          "opcode": "motion_changeyby",
          "inputs": {
            "DY": [
              1,
              [
                4,
                "50"
              ]
            ]
          }
        }
      }
    },
    {
      "name": "Platform",
      "costume": "banana",
      "x": 0,
      "y": -100,
      "blocks": {}
    }
  ]
}